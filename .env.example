# Copy to .env and fill in values before running docker compose.
#
# Generate a secure JWT secret:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# Required
JWT_SECRET=change-me-generate-a-real-secret-before-deploying

# Comma-separated list of origins allowed to call the API.
# Set this to whatever URL you access the app from.
# Examples:
#   http://192.168.1.100
#   https://chef.example.com
#   https://chef.example.com,https://www.chef.example.com
CORS_ORIGINS=http://localhost

# Pin a specific release tag instead of always pulling latest
IMAGE_TAG=latest

# Host port the app is served on (default: 80)
PORT=80

# Token lifetime in seconds (default: 30 days)
# JWT_LIFETIME_SECONDS=2592000
