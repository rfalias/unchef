# Copy to .env and fill in values before running docker compose.
#
# Generate a secure JWT secret:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# Required
JWT_SECRET=change-me-generate-a-real-secret-before-deploying

# Your ghcr.io image path — set to your GitHub username and repo name.
# After pushing to GitHub, images land at:
#   ghcr.io/GITHUB_USERNAME/REPO_NAME/backend:latest
#   ghcr.io/GITHUB_USERNAME/REPO_NAME/frontend:latest
GHCR_REPO=ghcr.io/rfalias/unchef

# Pin a specific release tag instead of always pulling latest
IMAGE_TAG=latest

# Host port the app is served on (default: 80)
PORT=80
